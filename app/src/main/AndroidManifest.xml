<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- No camera permission needed - benchmark only! -->

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        tools:targetApi="31"
        tools:ignore="MissingApplicationIcon">

        <!-- Main Activity - Auto-launches test/benchmark -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Test Activity - Diagnostic checks -->
        <activity
            android:name=".TestActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Model Test" />

        <!-- Benchmark Activity - Shows results -->
        <activity
            android:name=".BenchmarkActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="Model Benchmark" />
    </application>

</manifest>
```

